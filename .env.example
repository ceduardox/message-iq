# Core app
NODE_ENV=development
PORT=5000
APP_BASE_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Admin login
ADMIN_USER=admin
ADMIN_PASS=change_me

# Sessions
# Recommended in production: postgres
SESSION_STORE=postgres
SESSION_SECRET=change_this_to_a_long_random_secret

# WhatsApp Cloud API / Meta
META_ACCESS_TOKEN=your_meta_access_token
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_VERIFY_TOKEN=your_webhook_verify_token

# AI
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=

# Voice / audio
ELEVENLABS_API_KEY=
FFMPEG_PATH=

# OneSignal push notifications
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# If you need more than one segment, separate them with commas.
ONESIGNAL_SEGMENTS=Subscribed Users
# Legacy fallback. Prefer ONESIGNAL_SEGMENTS.
ONESIGNAL_SEGMENT=
# Optional frontend injection. If empty, the app falls back to /api/public-config.
VITE_ONESIGNAL_APP_ID=

# Replit-only connector fallback for ElevenLabs
REPLIT_CONNECTORS_HOSTNAME=
REPL_IDENTITY=
WEB_REPL_RENEWAL=
